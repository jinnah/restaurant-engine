# Restaurant Engine — environment template
#
# Copy to `.env` for local development. `.env` is gitignored and must never
# be committed. Every variable added here must use a safe placeholder value,
# never a real credential.
#
# The backend reads these from the process environment or a local `.env`
# file. Values below match the development database defined in compose.yaml.

# Application environment: development | test | production
APP_ENV=development

# SQLAlchemy database URL. The compose development database listens on
# 127.0.0.1:5433 only (5432 is occupied by an unrelated native PostgreSQL
# service). Use 127.0.0.1, not localhost: the container does not bind the
# IPv6 loopback, and the dead ::1 attempt adds ~5s to every connection.
DATABASE_URL=postgresql+psycopg://restaurant_dev:restaurant_dev_only@127.0.0.1:5433/restaurant_engine

# Minimum log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
