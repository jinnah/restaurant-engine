# Restaurant Engine — environment template
#
# Copy to `.env` for local development. `.env` is gitignored and must never
# be committed. Every variable added here must use a safe placeholder value,
# never a real credential.
#
# The backend reads these from the process environment or a local `.env`
# file. Values below match the development database defined in compose.yaml.

# Application environment: development | test | production
APP_ENV=development

# SQLAlchemy database URL. The compose development database listens on
# 127.0.0.1:5433 only (5432 is occupied by an unrelated native PostgreSQL
# service). Use 127.0.0.1, not localhost: the container does not bind the
# IPv6 loopback, and the dead ::1 attempt adds ~5s to every connection.
DATABASE_URL=postgresql+psycopg://restaurant_dev:restaurant_dev_only@127.0.0.1:5433/restaurant_engine

# Minimum log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Sessions and browser security (M2A, ADR-010) ---------------------------
# All three have safe defaults; set them only to deviate.

# Server-side session validity bounds.
#SESSION_IDLE_TIMEOUT_MINUTES=1440
#SESSION_ABSOLUTE_LIFETIME_DAYS=30

# Comma-separated exact origins allowed to originate browser-facing unsafe
# requests (fail-closed CSRF check). Development default is the control
# center dev server; production requires https:// origins (validated at
# startup).
#TRUSTED_ORIGINS=http://localhost:5173

# --- Tenant resolution (M2C, ADR-013) ---------------------------------------
# The platform base domain. A public request whose Host is a DIRECT subdomain
# of this domain resolves that label to a Business slug (e.g. with the default
# below, http://shalik.localhost:8000/api/v1/public/site resolves "shalik").
# Bare localhost and IP literals never resolve a Business. Production must set
# a real domain — 'localhost' is rejected at startup.
#PLATFORM_BASE_DOMAIN=localhost

# --- Onboarding and recovery tokens (M2D, ADR-014) --------------------------
# Single-use token lifetimes (bounded: 1-30 days / 5-1440 minutes). Both have
# safe defaults; set them only to deviate.
#INVITATION_EXPIRY_DAYS=7
#PASSWORD_RESET_EXPIRY_MINUTES=60

# --- Media storage (M3C, ADR-017) -------------------------------------------
# Filesystem root for stored media objects. Development defaults to a
# gitignored path inside the repo (backend/var/media); PRODUCTION must set an
# explicit, absolute, durable directory OUTSIDE any publicly served static
# path, mounted on a persistent volume (never inside the ephemeral container
# filesystem). Startup fails fast if the production root is missing or
# unwritable.
#MEDIA_STORAGE_ROOT=/srv/restaurant-engine/media
# Uploaded-file size cap in bytes (the file payload, not multipart overhead).
# The only deployment-tunable media limit; bounded 10-20 MiB. Default 10 MiB.
#MEDIA_UPLOAD_MAX_BYTES=10485760
