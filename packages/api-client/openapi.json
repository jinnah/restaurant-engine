{
  "components": {
    "schemas": {
      "CheckResult": {
        "properties": {
          "status": {
            "enum": [
              "up",
              "down"
            ],
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status"
        ],
        "title": "CheckResult",
        "type": "object"
      },
      "ErrorCode": {
        "description": "Machine-readable error code registry (append-only).",
        "enum": [
          "validation_error",
          "not_found",
          "method_not_allowed",
          "http_error",
          "internal_error",
          "dependency_unavailable"
        ],
        "title": "ErrorCode",
        "type": "string"
      },
      "ErrorDetail": {
        "properties": {
          "code": {
            "$ref": "#/components/schemas/ErrorCode"
          },
          "correlation_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Correlation Id"
          },
          "details": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Details"
          },
          "field_errors": {
            "default": [],
            "items": {
              "$ref": "#/components/schemas/FieldError"
            },
            "title": "Field Errors",
            "type": "array"
          },
          "message": {
            "title": "Message",
            "type": "string"
          }
        },
        "required": [
          "code",
          "message",
          "correlation_id"
        ],
        "title": "ErrorDetail",
        "type": "object"
      },
      "ErrorEnvelope": {
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ErrorDetail"
          }
        },
        "required": [
          "error"
        ],
        "title": "ErrorEnvelope",
        "type": "object"
      },
      "FieldError": {
        "properties": {
          "code": {
            "title": "Code",
            "type": "string"
          },
          "field": {
            "title": "Field",
            "type": "string"
          },
          "message": {
            "title": "Message",
            "type": "string"
          }
        },
        "required": [
          "field",
          "code",
          "message"
        ],
        "title": "FieldError",
        "type": "object"
      },
      "LivenessResponse": {
        "properties": {
          "status": {
            "const": "alive",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status"
        ],
        "title": "LivenessResponse",
        "type": "object"
      },
      "ReadinessResponse": {
        "properties": {
          "checks": {
            "additionalProperties": {
              "$ref": "#/components/schemas/CheckResult"
            },
            "title": "Checks",
            "type": "object"
          },
          "status": {
            "const": "ready",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status",
          "checks"
        ],
        "title": "ReadinessResponse",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "Restaurant Engine API",
    "version": "0.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/health/live": {
      "get": {
        "description": "Report that the process is up and able to serve HTTP.",
        "operationId": "health_live",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LivenessResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health Live",
        "tags": [
          "health"
        ]
      }
    },
    "/health/ready": {
      "get": {
        "description": "Report whether essential dependencies are reachable.\n\nThe check is deliberately cheap (bounded-timeout SELECT 1). The process\nstarts even when the database is down and reports 503 here until it\nrecovers — readiness gates traffic, liveness gates restarts.\n\nNot-ready is an error state, so it uses the ADR-008 envelope\n(``dependency_unavailable``) with the failing checks preserved in\n``error.details.checks``.",
        "operationId": "health_ready",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadinessResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Service Unavailable"
          }
        },
        "summary": "Health Ready",
        "tags": [
          "health"
        ]
      }
    }
  }
}
